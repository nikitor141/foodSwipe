{
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@components/*": ["src/components/*"],
			"@utils/*": ["src/utils/*"],
			"@core/*": ["src/core/*"],
			"@/*": ["src/*"]
		},
		"module": "ES2022",
		"target": "es2022",

		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		/* Vite specific */
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"types": ["vite/client"]
	},
	"exclude": ["node_modules"]
}
